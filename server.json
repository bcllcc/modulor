{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.bcllcc/modulor",
  "description": "Agent-native 2D drafting + 3D modeling CAD. Draw floor plans, model buildings and parts, render verification images, export DXF/SVG/STL/GLB and semantic IFC4 BIM, import real-world DXF.",
  "repository": {
    "url": "https://github.com/bcllcc/modulor",
    "source": "github"
  },
  "version": "0.6.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "modulor",
      "version": "0.6.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "modulor",
          "valueHint": "modulor"
        },
        {
          "type": "positional",
          "value": "mcp",
          "valueHint": "mcp"
        }
      ]
    }
  ]
}
