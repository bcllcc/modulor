{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.bcllcc/modulor",
  "description": "Agent-native CAD: draw plans, model 3D, render checks, export DXF/SVG/STL/GLB/IFC, import DXF.",
  "repository": {
    "url": "https://github.com/bcllcc/modulor",
    "source": "github"
  },
  "version": "0.6.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "modulor",
      "version": "0.6.1",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "modulor",
          "valueHint": "modulor"
        },
        {
          "type": "positional",
          "value": "mcp",
          "valueHint": "mcp"
        }
      ]
    }
  ]
}